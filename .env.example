# Copy this file to `.env` in the repo root and adjust values.
# The launcher (`python run_local.py`) will load these automatically.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_SECRET=change-me-for-local-development
TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=*

# Optional: leave unset to use local SQLite automatically.
# Example free cloud Postgres URL (Neon/Supabase):
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/database

# Auto-seed database using synthetic telemetry when empty.
AUTO_SEED_DATA=true
SEED_MACHINES=5
SEED_HOURS=336

# Lumo+ ask assistant mode:
# - local  -> fully local KPI/telemetry analysis (default; no API key needed)
# - auto   -> use OpenAI if key exists, otherwise fallback to local
# - openai -> force OpenAI mode (requires OPENAI_API_KEY)
LUMO_MODE=local

# Optional OpenAI settings (only needed for LUMO_MODE=openai or auto+key)
OPENAI_API_KEY=
LUMO_MODEL=gpt-4o-mini
